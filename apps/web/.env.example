# Backend API base URL. Use http://localhost:3001 for local dev or the live
# tunnel URL (e.g. https://ethsec-xerxes.loca.lt) for hosted/tunnelled mode.
# When the URL ends in .loca.lt, the client automatically attaches the
# `bypass-tunnel-reminder: true` header to every request.
VITE_API_BASE_URL=http://localhost:3001

# ERC-721 badge contract address (mainnet by default).
VITE_BADGE_CONTRACT=0xf67c0ade41c607efebf198f9d6065ab1ec5ad4cd

# Chain id the user must be on. 1 = mainnet, 11155111 = Sepolia (Phase 8).
VITE_CHAIN_ID=1

# WalletConnect project id. Optional — injected wallets (MetaMask, Rabby) work
# without it. Leave the placeholder unless you know you need WalletConnect.
VITE_WALLETCONNECT_PROJECT_ID=
