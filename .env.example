# Root .env — consumed by docker-compose.yml.
# Copy to `.env` and fill in the real values.

# ----- Domain -----
# Leave as ":80" for local testing over plain HTTP. Set to a real domain
# (A/AAAA records must already point here) to enable auto-HTTPS via
# Caddy + Let's Encrypt.
CADDY_DOMAIN=:80
HTTP_PORT=80
HTTPS_PORT=443

# ----- Database -----
POSTGRES_PASSWORD=replace_with_a_strong_password

# ----- Badge NFT (onchain) -----
# Mainnet ETHSecurity Badge:
BADGE_CONTRACT=0xf67c0ade41c607efebf198f9d6065ab1ec5ad4cd
CHAIN_ID=1
RPC_URL=https://ethereum-rpc.publicnode.com

# ----- Admin secrets -----
# Generate on YOUR machine (see README "Admin lifecycle"). Never commit.
#   public key:  pnpm --filter @ethsec/scripts keygen ./keys   → keys/public.key
#   token:       node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_PUBLIC_KEY_HEX=0x_REPLACE_WITH_CONTENTS_OF_keys_public.key
ADMIN_EXPORT_TOKEN=REPLACE_WITH_64_HEX_CHARS_FROM_CRYPTO_RANDOMBYTES

# ----- Web-only -----
# WalletConnect project id — sign up at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=

# ----- CORS -----
# Same-origin deployments can leave as "*". Set to the exact web origin
# if you split web + api across different hosts.
CORS_ALLOWED_ORIGIN=*
